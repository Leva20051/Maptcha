DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cafe_curator

# Optional: use a single connection string instead of the DB_* values above.
# DATABASE_URL=mysql://root:your_mysql_password@127.0.0.1:3306/cafe_curator

# For TiDB Cloud or other TLS-only MySQL-compatible services.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_MIN_VERSION=TLSv1.2

# Vercel/TiDB Cloud works best with a small pool size.
DB_CONNECTION_LIMIT=10
DB_MAX_IDLE=10
DB_ENABLE_KEEP_ALIVE=true

# Shared cloud setup:
# SEED_DEMO_DATA=false
# ADMIN_USERNAME=youradmin
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=use-a-strong-password
# ADMIN_LEVEL=Super

SESSION_SECRET=replace-with-a-long-random-secret
